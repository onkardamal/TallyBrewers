# Copy this file to .env (or export these as real environment variables)
# and fill in real values. Never commit an actual .env file.

# Database
DB_HOST=localhost
DB_PORT=5432
DB_NAME=securebank
DB_USERNAME=securebank_app
DB_PASSWORD=

# SMTP
# Option A (production / real email): Gmail App Password or another provider.
#   SMTP_HOST=smtp.gmail.com, SMTP_PORT=587, SMTP_AUTH=true, SMTP_STARTTLS=true
# Option B (local dev): a local catcher such as Mailpit (https://mailpit.axllent.org).
#   Run `mailpit`, then use the values below. View captured mail at http://localhost:8025
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_AUTH=false
SMTP_STARTTLS=false
MAIL_FROM=no-reply@securebank.local

# WebAuthn (Relying Party) - keep as localhost for development
WEBAUTHN_RP_ID=localhost
WEBAUTHN_RP_NAME=SecureBank
WEBAUTHN_ORIGIN=http://localhost:5173

# JWT
JWT_ACCESS_TTL_MINUTES=15
JWT_REFRESH_TTL_DAYS=30

SERVER_PORT=8080
